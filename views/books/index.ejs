<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<!-- Main Content -->
<main class="main-content">
    <div class="container">
        <!-- Page Header -->
        <div class="page-header">
            <div class="header-content">
                <h1 class="page-title">
                    <% if (search) { %>
                        <i class="fas fa-search"></i>
                        Search Results for "<%= search %>"
                    <% } else { %>
                        <i class="fas fa-book"></i>
                        All Books
                    <% } %>
                </h1>
                <p class="page-subtitle">
                    <% if (search) { %>
                        Found <%= totalBooks %> book<%= totalBooks !== 1 ? 's' : '' %>
                    <% } else { %>
                        Manage and read your digital book collection
                    <% } %>
                </p>
            </div>
            <a href="/books/new" class="btn btn-primary btn-lg">
                <i class="fas fa-plus"></i>
                Add New Book
            </a>
        </div>

        <!-- Search Bar -->
        <div class="search-section">
            <form action="/books" method="GET" class="search-form">
                <div class="search-input-wrapper">
                    <i class="fas fa-search search-icon"></i>
                    <input 
                        type="text" 
                        name="search" 
                        class="search-input" 
                        placeholder="Search by title, author, or genre..."
                        value="<%= search %>"
                    >
                    <% if (search) { %>
                        <a href="/books" class="search-clear" title="Clear search">
                            <i class="fas fa-times"></i>
                        </a>
                    <% } %>
                </div>
                <button type="submit" class="btn btn-secondary">Search</button>
            </form>
        </div>

        <!-- Books Grid -->
        <% if (books && books.length > 0) { %>
            <div class="books-grid">
                <% books.forEach(book => { %>
                    <article class="book-card">
                        <!-- Cover Image -->
                        <div class="book-cover">
                            <% if (book.coverImage) { %>
                                <% if (book.coverImage.startsWith('http')) { %>
                                    <img src="<%= book.coverImage %>" alt="<%= book.title %>">
                                <% } else { %>
                                    <img src="<%= book.coverImage %>" alt="<%= book.title %>">
                                <% } %>
                            <% } else { %>
                                <div class="book-cover-placeholder">
                                    <i class="fas fa-book"></i>
                                    <span><%= book.title.charAt(0).toUpperCase() %></span>
                                </div>
                            <% } %>
                            <div class="book-overlay">
                                <a href="/books/<%= book._id %>" class="btn btn-white">
                                    <i class="fas fa-eye"></i> View
                                </a>
                            </div>
                        </div>

                        <!-- Book Info -->
                        <div class="book-info">
                            <h3 class="book-title" title="<%= book.title %>">
                                <%= book.title %>
                            </h3>
                            <p class="book-author">
                                <i class="fas fa-user"></i>
                                <%= book.author %>
                            </p>
                            <% if (book.genre) { %>
                                <span class="book-genre">
                                    <i class="fas fa-tag"></i>
                                    <%= book.genre %>
                                </span>
                            <% } %>
                            <% if (book.description) { %>
                                <p class="book-description">
                                    <%= book.description.substring(0, 100) %>
                                    <%= book.description.length > 100 ? '...' : '' %>
                                </p>
                            <% } %>
                        </div>

                        <!-- Book Actions -->
                        <div class="book-actions">
                            <a href="/books/<%= book._id %>" class="btn btn-outline btn-sm" title="View Details">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a href="/books/<%= book._id %>/edit" class="btn btn-outline btn-sm" title="Edit Book">
                                <i class="fas fa-edit"></i>
                            </a>
                            <button type="button" class="btn btn-danger btn-sm" title="Delete Book" onclick="showDeleteModal('<%= book._id %>', 'book')">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </article>
                <% }) %>
            </div>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
                <nav class="pagination">
                    <% if (hasPrevPage) { %>
                        <a href="/books?page=<%= prevPage %><%= search ? '&search=' + encodeURIComponent(search) : '' %>&limit=<%= limit %>" class="pagination-btn">
                            <i class="fas fa-chevron-left"></i>
                            Previous
                        </a>
                    <% } else { %>
                        <span class="pagination-btn disabled">
                            <i class="fas fa-chevron-left"></i>
                            Previous
                        </span>
                    <% } %>

                    <div class="pagination-info">
                        Page <%= currentPage %> of <%= totalPages %>
                        <span class="pagination-total">(<%= totalBooks %> books)</span>
                    </div>

                    <% if (hasNextPage) { %>
                        <a href="/books?page=<%= nextPage %><%= search ? '&search=' + encodeURIComponent(search) : '' %>&limit=<%= limit %>" class="pagination-btn">
                            Next
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    <% } else { %>
                        <span class="pagination-btn disabled">
                            Next
                            <i class="fas fa-chevron-right"></i>
                        </span>
                    <% } %>
                </nav>
            <% } %>
        <% } else { %>
            <!-- Empty State -->
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-book-open"></i>
                </div>
                <h2>No Books Found</h2>
                <% if (search) { %>
                    <p>No books match your search for "<%= search %>".</p>
                    <a href="/books" class="btn btn-primary">
                        <i class="fas fa-arrow-left"></i>
                        View All Books
                    </a>
                <% } else { %>
                    <p>Your library is empty. Start building your collection by adding your first book.</p>
                    <a href="/books/new" class="btn btn-primary btn-lg">
                        <i class="fas fa-plus"></i>
                        Add Your First Book
                    </a>
                <% } %>
            </div>
        <% } %>
    </div>
</main>

<!-- Delete Password Modal -->
<div id="deleteModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-lock"></i> Delete Protection</h3>
            <button type="button" class="modal-close" onclick="closeDeleteModal()">&times;</button>
        </div>
        <div class="modal-body">
            <p>Please enter the delete password to proceed:</p>
            <form id="deleteForm" method="POST">
                <input type="hidden" name="_method" value="DELETE">
                <div class="form-group">
                    <input 
                        type="password" 
                        name="deletePassword" 
                        class="form-input" 
                        placeholder="Enter delete password"
                        required
                        autofocus
                    >
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn btn-outline" onclick="closeDeleteModal()">Cancel</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function showDeleteModal(id, type) {
        const modal = document.getElementById('deleteModal');
        const form = document.getElementById('deleteForm');
        form.action = type === 'book' ? `/books/${id}?_method=DELETE` : `/shelves/${id}?_method=DELETE`;
        modal.style.display = 'flex';
    }

    function closeDeleteModal() {
        const modal = document.getElementById('deleteModal');
        modal.style.display = 'none';
    }

    // Close modal when clicking outside
    window.onclick = function(event) {
        const modal = document.getElementById('deleteModal');
        if (event.target === modal) {
            modal.style.display = 'none';
        }
    }
</script>

<%- include('../partials/footer') %>
